# Copy to .env.cloudos.local and replace placeholders with approved private values.
# Do not commit real CloudOS URLs, API keys, workspace IDs, bucket names, or
# internal registry hostnames.

CLOUDOS_PROFILE=offline-smoke
CLOUDOS_URL=https://cloudos.example.internal
CLOUDOS_APIKEY=replace-with-local-secret
CLOUDOS_WORKSPACE_ID=workspace-id
CLOUDOS_PROJECT_NAME=project-name
CLOUDOS_WORKFLOW_NAME=nf-core/testpipeline
CLOUDOS_JOB_QUEUE=queue-name
CLOUDOS_EXECUTION_PLATFORM=aws
CLOUDOS_REPOSITORY_PLATFORM=github
CLOUDOS_NEXTFLOW_VERSION=25.04.8
CLOUDOS_NEXTFLOW_PROFILE=docker,test
CLOUDOS_JOB_NAME=nf-core-testpipeline-offline-smoke
CLOUDOS_INSTANCE_TYPE=c5.large
CLOUDOS_INSTANCE_DISK_GB=100
CLOUDOS_WAIT_SECONDS=1800
CLOUDOS_COST_LIMIT=2

NEXUS_DOCKER_REGISTRY=nexus-docker-quay.example.internal
S3_ROOT=s3://example-bucket/nextflow-offline/cloudos/
AWS_REGION=ap-southeast-1
AWS_PROFILE=replace-with-local-profile
