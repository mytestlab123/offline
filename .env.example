# Copy to .env and fill with private values for your environment.
# Do not commit .env.

AWS_PROFILE=default
AWS_REGION=ap-southeast-1

# Private EC2 validation inputs.
NEXTFLOW_VALIDATION_EXPECTED_ACCOUNT=
NEXTFLOW_VALIDATION_AMI_ID=
NEXTFLOW_VALIDATION_SUBNET_ID=
NEXTFLOW_VALIDATION_SECURITY_GROUP_ID=
NEXTFLOW_VALIDATION_INSTANCE_PROFILE=

# Private artifact locations.
NEXTFLOW_OFFLINE_REPO_S3_URI=s3://example-bucket/git/nextflow-offline/repo/
NEXTFLOW_OFFLINE_TOOLS_S3_URI=s3://example-bucket/nextflow-offline/tools/nextflow-tools.tar.gz
NEXTFLOW_OFFLINE_BUNDLE_S3_URI=s3://example-bucket/nextflow-offline/bundles/testpipeline-3.2.1/

# Private registry endpoint, if available from the target VPC.
NEXTFLOW_OFFLINE_NEXUS_HOST=nexus-docker.example.internal
